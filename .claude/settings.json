{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/pre-commit-review.sh",
            "timeout": 10,
            "statusMessage": "Verificando review pre-commit..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/run-tests.sh",
            "timeout": 120,
            "statusMessage": "Ejecutando tests..."
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/git-status-reminder.sh",
            "timeout": 10,
            "statusMessage": "Verificando git..."
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/memory-sync.sh",
            "timeout": 15,
            "statusMessage": "Sincronizando memorias..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/lint-on-edit.sh",
            "timeout": 30,
            "statusMessage": "Linting..."
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/complexity-check.sh",
            "timeout": 15,
            "statusMessage": "Verificando complejidad..."
          }
        ]
      }
    ]
  },
  "context": {
    "autoInject": [
      ".claude/rules/*.md"
    ],
    "maxTokens": 24000
  },
  "project": {
    "name": "KobetsuV3",
    "description": "Proyecto integrado con Antigravity Agents"
  },
  "cleanupPeriodDays": 60,
  "outputStyle": "Gentleman",
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".venv",
      "__pycache__"
    ]
  }
}