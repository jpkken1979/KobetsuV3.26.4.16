{
  "name": "kobetsu-v3",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "description": "個別契約書管理システム — ユニバーサル企画株式会社",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"tsx watch --env-file .env server/index.ts\" \"vite\"",
    "dev:server": "tsx watch --env-file .env server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx server/db/seed.ts",
    "db:seed:force": "tsx server/db/seed.ts --force",
    "test": "npm run test:prepare && vitest --no-file-parallelism",
    "test:prepare": "cross-env DATABASE_PATH=data/kobetsu.test.db tsx server/db/seed.ts --force",
    "test:run": "npm run test:prepare && cross-env DATABASE_PATH=data/kobetsu.test.db vitest run --no-file-parallelism",
    "test:coverage": "npm run test:prepare && cross-env DATABASE_PATH=data/kobetsu.test.db vitest run --no-file-parallelism --coverage",
    "test:pdf-snapshots:update": "cross-env UPDATE_PDF_SNAPSHOTS=1 vitest run server/__tests__/pdf-snapshots.test.ts",
    "lint": "eslint src/ server/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/noto-sans-jp": "^5.2.10",
    "@fontsource-variable/noto-serif-jp": "^5.2.9",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@hono/node-server": "^2.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.6",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.22",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "hono": "^4.12.15",
    "lucide-react": "^1.12.0",
    "motion": "^12.38.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "yazl": "^3.3.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/router-devtools": "^1.166.9",
    "@tanstack/router-plugin": "^1.167.28",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.5.0",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sharp": "^0.31.1",
    "@types/yazl": "^3.3.0",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.4.0",
    "jsdom": "^29.1.0",
    "pdfjs-dist": "^5.7.284",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
}
